# KSP Crime AI — Backend environment configuration
# Copy to `.env` and adjust for your deployment. NEVER commit real secrets.

# --- Database ---
# SQLite (default, dev):
# DATABASE_URL=sqlite:///./ksp_crime_ai.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/ksp_crime_ai

# --- Authentication ---
# Change this to a long random string in production.
KSP_SECRET_KEY=change-me-to-a-long-random-secret
# Salt used for password hashing.
KSP_PW_SALT=change-me-too
# Token validity in seconds (default 8 hours).
KSP_TOKEN_TTL=28800
# Set to false ONLY for local demos to bypass login.
KSP_AUTH_REQUIRED=true

# --- API / CORS ---
# Comma-separated list of allowed frontend origins.
KSP_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Expose generated SQL in responses (debugging only — keep false in prod).
KSP_EXPOSE_SQL=false
